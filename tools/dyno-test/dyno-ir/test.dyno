    hw.INPUT_REGISTER_DEF %r4:register(1)
    hw.INPUT_REGISTER_DEF %r5:register(1)
    hw.INPUT_REGISTER_DEF %r6:register(1)
    hw.OUTPUT_REGISTER_DEF %r7:register(32)
