      LOAD %sc_v:wire(1), %sel_c
      LOAD %sd_v:wire(1), %sel_d
      LOAD %sab_v:wire(1), %sel_ab

      ONEHOT_MUX %tmp:wire(32), %sa_v, %a_v, %sb_v, %b_v
      ONEHOT_MUX %val:wire(32), %sab_v, %tmp, %sc_v, %c_v, %sd_v, %d_v
      STORE %val, %out_a
    }
  }
}{
