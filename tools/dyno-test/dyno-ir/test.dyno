TEST_CASE :string("flip-flop-inference-rst-clk-en"), :block, :block, :block {
  MODULE_DEF :module("mod"), :block {
    INPUT_REGISTER_DEF %clk:register(1)
    INPUT_REGISTER_DEF %rst:register(1)
    INPUT_REGISTER_DEF %in_a:register(32)
    INPUT_REGISTER_DEF %in_en:register(1)
    OUTPUT_REGISTER_DEF %out_a:register(32)

    TRIGGER_DEF %trig:trigger(pos, pos), %clk, %rst

    COMB_PROCESS_DEF :process, :block {
      LOAD %a_v:wire(32), %in_a
      LOAD %en_v:wire(1), %in_en
      LOAD %rst_v:wire(1), %rst
      LOAD %old_a_v:wire(32), %out_a

      NOT %not_en:wire(1), %en_v
      NOT %not_rst:wire(1), %rst_v

      AND %en_gated:wire(1), %en_v, %not_rst
      AND %not_en_gated:wire(1), %not_en, %not_rst

      ONEHOT_MUX %d:wire(32), %en_gated, %a_v, %not_en_gated, %old_a_v, %rst_v, #32'h0
      STORE_DEFER %d, %out_a, %trig
    }
  }
}{
hw.MODULE_DEF :module("mod"), :core.block {
    hw.INPUT_REGISTER_DEF %r5:register(1)
    hw.INPUT_REGISTER_DEF %r6:register(1)
    hw.INPUT_REGISTER_DEF %r7:register(32)
    hw.INPUT_REGISTER_DEF %r8:register(1)
    hw.OUTPUT_REGISTER_DEF %r9:register(32)
    hw.TRIGGER_DEF :trigger(pos, pos), %r5, %r6
    hw.COMB_PROCESS_DEF :process, :core.block {
      hw.LOAD %w9:wire(32), %r7
      hw.LOAD %w10:wire(1), %r8
      hw.LOAD %w11:wire(1), %r6
      hw.LOAD %w12:wire(32), %r9
      op.NOT %w13:wire(1), %w11
      op.OR %w14:wire(1), %w10, %w11
      op.NOT %w15:wire(1), %w14
      hw.ONEHOT_MUX %w16:wire(32), %w10, %w9, %w15, %w12
      hw.ASSUME %w17:wire(1), %w15, %w13
      op.NOT %w18:wire(1), %w17
      op.OR %w19:wire(1), %w11, %w17
      op.NOT %w20:wire(1), %w19
      hw.ASSUME %w21:wire(32), %w16, %w20
      hw.LOAD %w22:wire(1), %r5
      hw.FLIP_FLOP %w23:wire(32), %w22, %w21, %w18, %w11, #32'd0
      hw.STORE %w23, %r9
    }
  }
}{
  meta.FLIP_FLOP_INFERENCE_PASS
  meta.COMMON_SUBEXPRESSION_ELIMINATION_PASS
  meta.INST_COMBINE_PASS
}


TEST_CASE :string("instcombine-mux-lift"), :block, :block, :block {
  MODULE_DEF :module("mod"), :block {
    INPUT_REGISTER_DEF %clk:register(1)
    INPUT_REGISTER_DEF %rst:register(1)
    INPUT_REGISTER_DEF %in_a:register(32)
    INPUT_REGISTER_DEF %in_b:register(32)
