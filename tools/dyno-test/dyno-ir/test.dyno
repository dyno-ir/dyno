    INPUT_REGISTER_DEF %in_sel:register(1)
    OUTPUT_REGISTER_DEF %out_a:register(96)

    TRIGGER_DEF %trig:trigger(pos, pos), %clk, %rst

    COMB_PROCESS_DEF :process, :block {
      LOAD %a_v:wire(32), %in_a
      LOAD %b_v:wire(32), %in_b
      LOAD %a2_v:wire(32), %in_a2
      LOAD %b2_v:wire(32), %in_b2
      LOAD %sel_v:wire(1), %in_sel
      NOT %nsel:wire(1), %sel_v

      ONEHOT_MUX %first:wire(32), %sel_v, %a_v, %nsel, %b_v
      ONEHOT_MUX %second:wire(32), %sel_v, %a2_v, %nsel, %b2_v

      CONCAT %v:wire(96), %first, %second, #32'h0
      STORE %v, %out_a
    }
  }
}{
