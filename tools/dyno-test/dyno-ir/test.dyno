    INPUT_REGISTER_DEF %sel_b:register(1)
    INPUT_REGISTER_DEF %sel_c:register(1)
    INPUT_REGISTER_DEF %sel_d:register(1)
    INPUT_REGISTER_DEF %sel_ab:register(1)

    OUTPUT_REGISTER_DEF %out_a:register(32)

