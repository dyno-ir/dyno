    hw.INPUT_REGISTER_DEF %clk:register(1)
    hw.INPUT_REGISTER_DEF %rst:register(1)
    hw.INPUT_REGISTER_DEF %in_a:register(32)
    hw.INPUT_REGISTER_DEF %in_b:register(32)
    hw.INPUT_REGISTER_DEF %in_a2:register(32)
    hw.INPUT_REGISTER_DEF %in_b2:register(32)
    hw.INPUT_REGISTER_DEF %in_sel:register(1)
    hw.OUTPUT_REGISTER_DEF %out_a:register(96)
    hw.TRIGGER_DEF %5:trigger(pos, pos), %clk, %rst
    hw.COMB_PROCESS_DEF %6:process, %7:core.block {
      hw.LOAD %w0:wire(32), %in_a
      hw.LOAD %w1:wire(32), %in_b
      hw.LOAD %w2:wire(32), %in_a2
      hw.LOAD %w3:wire(32), %in_b2
      hw.LOAD %w4:wire(1), %in_sel
      op.NOT %w5:wire(1), %w4
      hw.CONCAT %w9:wire(64), %w0, %w2
      hw.CONCAT %w10:wire(64), %w1, %w3
      hw.ONEHOT_MUX %w11:wire(64), %w4, %w9, %w5, %w10
      hw.CONCAT %w12:wire(96), %w11, #32'd0
      hw.STORE %w12, %out_a
    }
  }
}{
  meta.INST_COMBINE_PASS
}


TEST_EQUIVALENCE :string("test-arith-lower"), :block, :block {
  MODULE_DEF :module("mod"), :block {
    INPUT_REGISTER_DEF %clk:register(1)
    INPUT_REGISTER_DEF %in_a:register(32)
    INPUT_REGISTER_DEF %in_b:register(32)
    INPUT_REGISTER_DEF %in_c:register(32)
    OUTPUT_REGISTER_DEF %out_sum:register(32)
    OUTPUT_REGISTER_DEF %out_and:register(32)
    OUTPUT_REGISTER_DEF %out_or:register(32)
    OUTPUT_REGISTER_DEF %out_xor:register(32)
    OUTPUT_REGISTER_DEF %out_mul:register(32)

    COMB_PROCESS_DEF :process, :block {
      LOAD %a_v:wire(32), %in_a
      LOAD %b_v:wire(32), %in_b
      LOAD %c_v:wire(32), %in_c

      ADD %sum:wire(32), %a_v, %b_v, %c_v
      AND %and:wire(32), %a_v, %b_v, %c_v
      OR %or:wire(32), %a_v, %b_v, %c_v
      XOR %xor:wire(32), %a_v, %b_v, %c_v
      MUL %mul:wire(32), %a_v, %b_v, %c_v

      STORE %sum, %out_sum
      STORE %and, %out_and
      STORE %or, %out_or
      STORE %xor, %out_xor
      STORE %mul, %out_mul
    }
  }
}{
  meta.LOWER_OPS_PASS
  meta.INST_COMBINE_PASS
  meta.COMMON_SUBEXPRESSION_ELIMINATION_PASS
  meta.RANDOM_EQUIVALENCE_CHECK_PASS map("cycles": "1000")
}

TEST_EQUIVALENCE :string("test-icmp-lower"), :block, :block {
  MODULE_DEF :module("mod"), :block {
    INPUT_REGISTER_DEF %clk:register(1)
    INPUT_REGISTER_DEF %in_a:register(32)
    INPUT_REGISTER_DEF %in_b:register(32)
    OUTPUT_REGISTER_DEF %out_eq:register(1)
    OUTPUT_REGISTER_DEF %out_ne:register(1)
    OUTPUT_REGISTER_DEF %out_ult:register(1)
    OUTPUT_REGISTER_DEF %out_ule:register(1)
    OUTPUT_REGISTER_DEF %out_ugt:register(1)
    OUTPUT_REGISTER_DEF %out_uge:register(1)
    OUTPUT_REGISTER_DEF %out_slt:register(1)
    OUTPUT_REGISTER_DEF %out_sle:register(1)
    OUTPUT_REGISTER_DEF %out_sgt:register(1)
    OUTPUT_REGISTER_DEF %out_sge:register(1)

    COMB_PROCESS_DEF :process, :block {
      LOAD %a_v:wire(32), %in_a
      LOAD %b_v:wire(32), %in_b

      ICMP_EQ  %eq_v:wire(1), %a_v, %b_v
      ICMP_NE  %ne_v:wire(1), %a_v, %b_v
      ICMP_ULT %ult_v:wire(1), %a_v, %b_v
      ICMP_ULE %ule_v:wire(1), %a_v, %b_v
      ICMP_UGT %ugt_v:wire(1), %a_v, %b_v
      ICMP_UGE %uge_v:wire(1), %a_v, %b_v
      ICMP_SLT %slt_v:wire(1), %a_v, %b_v
      ICMP_SLE %sle_v:wire(1), %a_v, %b_v
      ICMP_SGT %sgt_v:wire(1), %a_v, %b_v
      ICMP_SGE %sge_v:wire(1), %a_v, %b_v

      STORE %eq_v, %out_eq
      STORE %ne_v, %out_ne
      STORE %ult_v, %out_ult
      STORE %ule_v, %out_ule
      STORE %ugt_v, %out_ugt
      STORE %uge_v, %out_uge
      STORE %slt_v, %out_slt
      STORE %sle_v, %out_sle
      STORE %sgt_v, %out_sgt
      STORE %sge_v, %out_sge
    }
  }
}{
  meta.LOWER_OPS_PASS
  meta.INST_COMBINE_PASS
  meta.COMMON_SUBEXPRESSION_ELIMINATION_PASS
  meta.RANDOM_EQUIVALENCE_CHECK_PASS map("cycles": "10000")
}

TEST_CASE :string("test-extract"), :block, :block, :block {
  MODULE_DEF :module("Test"), :block {
    INPUT_REGISTER_DEF %addr:register(2)
    INPUT_REGISTER_DEF %data:register(4)
    OUTPUT_REGISTER_DEF %out:register(1)

    COMB_PROCESS_DEF :process, :block {
      LOAD %addr_v:wire(2), %addr
      ZEXT %addr32:wire(32), %addr_v

      LOAD %data_v:wire(4), %data

      SPLICE %out_v:wire(1), %data_v, #32'd0, %addr32, #32'd1, #32'd4

      STORE %out_v, %out
    }
  }
}{
  hw.MODULE_DEF %Test:module("Test"), %4:core.block {
    hw.INPUT_REGISTER_DEF %r0:register(2)
    hw.INPUT_REGISTER_DEF %r1:register(4)
    hw.OUTPUT_REGISTER_DEF %r2:register(1)
    hw.COMB_PROCESS_DEF %5:process, %6:core.block {
      hw.LOAD %w0:wire(2), %r0
      hw.LOAD %w2:wire(4), %r1
      op.TRUNC %w8:wire(1), %w2
      hw.SPLICE %w9:wire(1), %w2, #32'd1
      hw.SPLICE %w10:wire(1), %w2, #32'd2
      hw.SPLICE %w11:wire(1), %w2, #32'd3
      op.TRUNC %w12:wire(1), %w0
      hw.SPLICE %w25:wire(1), %w0, #32'd1
      op.AND %w3:wire(1), %w12, %w25
      op.NOT %w17:wire(1), %w12
      op.AND %w18:wire(1), %w17, %w25
      op.NOT %w19:wire(1), %w25
      op.AND %w20:wire(1), %w12, %w19
      op.OR %w21:wire(1), %w12, %w25
      op.NOT %w24:wire(1), %w21
      hw.ONEHOT_MUX %w23:wire(1), %w24, %w8, %w20, %w9, %w18, %w10, %w3, %w11
      hw.STORE %w23, %r2
    }
  }
}{
  meta.LOWER_OPS_PASS
  meta.MUX_TREE_FLATTEN_PASS
  meta.COMMON_SUBEXPRESSION_ELIMINATION_PASS
  meta.INST_COMBINE_PASS
}

TEST_CASE :string("test-reg-split"), :block, :block, :block {
  MODULE_DEF :module("Test"), :block {
    INPUT_REGISTER_DEF %clk:register(1)
    INPUT_REGISTER_DEF %addr:register(2)
    INPUT_REGISTER_DEF %in_op:register(1)
    OUTPUT_REGISTER_DEF %out_a:register(1)

    REGISTER_DEF %state:register(4)

    TRIGGER_DEF %trig:trigger(pos), %clk

    COMB_PROCESS_DEF :process, :block {
      LOAD %state_v:wire(4), %state
      LOAD %addr_v:wire(2), %addr
      ZEXT %addr32:wire(32), %addr_v

      SPLICE %bit_v:wire(1), %state_v, #32'd0, %addr32, #32'd1, #32'd4

      STORE %bit_v, %out_a

      LOAD %in_op_v:wire(1), %in_op
      NOT %bit_v_inv:wire(1), %bit_v
      MUX %bit_v_out:wire(1), %in_op_v, #1'b0, %bit_v_inv

      INSERT %res_v:wire(4), %state_v, %bit_v_out, #32'd0, %addr32, #32'd1, #32'd4

      STORE_DEFER %res_v, %state, %trig
    }
  }
}{
  hw.MODULE_DEF %Test:module("Test"), %4:core.block {
    hw.INPUT_REGISTER_DEF %r0:register(1)
    hw.INPUT_REGISTER_DEF %r1:register(2)
    hw.INPUT_REGISTER_DEF %r2:register(1)
    hw.OUTPUT_REGISTER_DEF %r3:register(1)
    hw.REGISTER_DEF %r4:register(4)
    hw.TRIGGER_DEF %5:trigger(pos), %r0
    hw.COMB_PROCESS_DEF %6:process, %7:core.block {
      hw.LOAD %w0:wire(4), %r4
      hw.LOAD %w1:wire(2), %r1
      op.ZEXT %w2:wire(32), %w1
      op.TRUNC %w39:wire(1), %w0
      hw.SPLICE %w40:wire(1), %w0, #32'd1
      hw.SPLICE %w41:wire(1), %w0, #32'd2
      hw.SPLICE %w42:wire(1), %w0, #32'd3
      op.TRUNC %w43:wire(1), %w1
      op.NOT %w56:wire(1), %w43
      hw.SPLICE %w55:wire(1), %w1, #32'd1
      op.NOT %w54:wire(1), %w55
      op.AND %w57:wire(1), %w43, %w55
      op.AND %w58:wire(1), %w55, %w56
      op.AND %w61:wire(1), %w43, %w54
      op.OR %w64:wire(1), %w43, %w55
      op.NOT %w65:wire(1), %w64
      hw.ONEHOT_MUX %w63:wire(1), %w65, %w39, %w61, %w40, %w58, %w41, %w57, %w42
      hw.STORE %w63, %r3
      hw.LOAD %w4:wire(1), %r2
      op.OR %w52:wire(1), %w4, %w63
      op.NOT %w53:wire(1), %w52
      op.NOT %w16:wire(32), %w2
      op.TRUNC %w18:wire(1), %w16
      hw.SPLICE %w20:wire(1), %w16, #32'd1
      op.AND %w22:wire(1), %w18, %w55
      op.AND %w23:wire(1), %w20, %w43
      op.AND %w24:wire(1), %w18, %w20
      hw.LOAD %w50:wire(1), %r0
      hw.ASSUME %w30:wire(1), %w53, %w24
      // register split into 4 ffs with different clock enables
      hw.FLIP_FLOP %w21:wire(1), %w50, %w30, %w24
      hw.ASSUME %w17:wire(1), %w53, %w23
      hw.FLIP_FLOP %w67:wire(1), %w50, %w17, %w23
      hw.ASSUME %w68:wire(1), %w53, %w22
      hw.FLIP_FLOP %w70:wire(1), %w50, %w68, %w22
      hw.ASSUME %w71:wire(1), %w53, %w57
      hw.FLIP_FLOP %w73:wire(1), %w50, %w71, %w57
      hw.CONCAT %w36:wire(4), %w73, %w70, %w67, %w21
      hw.STORE %w36, %r4
    }
  }
}{
  meta.LOWER_OPS_PASS
  meta.INST_COMBINE_PASS map("muxToOneHotMux": "1")
  meta.COMMON_SUBEXPRESSION_ELIMINATION_PASS

  meta.FLIP_FLOP_INFERENCE_PASS
  meta.INST_COMBINE_PASS map("findFlipFlopEnables": "1")
}

// lower down to memory mapping
FUNCTION_DEF %memoryTestSynth:func, :block {
  CALL symbol("flow_earlyCanonFlow")
  meta.INACTIVE_COPY_PASS
  CALL symbol("flow_synthCanonicalize")
  CALL symbol("flow_synthEarlyOpt")
  CALL symbol("flow_synthLowerControlFlow")
  CALL symbol("flow_synthMemoryFFMuxHandling")
  CALL symbol("flow_synthLowerMemoryFF")
}
// lift back up for sim
FUNCTION_DEF %memoryTestLift:func, :block {
  meta.LIFT_STD_CELLS_PASS
  meta.SELECT_MODULES_PASS map("regex": "^(?!.*__inactive$).*")
  meta.MODULE_INLINE_PASS
  meta.SELECT_MODULES_PASS map("regex": "Test")
  meta.LOWER_MEM_ACCESS_PASS

  meta.LIFT_FLIP_FLOPS_PASS
  meta.TRIGGER_DEDUPE_PASS

  meta.PROCESS_LINEARIZE_PASS map("retainIODeps": "0", "retainInnerDeps": "0")
  meta.SSA_CONSTRUCT_PASS
  meta.COMMON_SUBEXPRESSION_ELIMINATION_PASS
  meta.INST_COMBINE_PASS
  meta.AGGRESSIVE_DEAD_CODE_ELIMINATION_PASS

  meta.ORDER_INSTRS_PASS map("assertNoCircularDeps": "1", "moveStoresBeforeLoads": "1")
  meta.SSA_CONSTRUCT_PASS
  meta.COMMON_SUBEXPRESSION_ELIMINATION_PASS
  meta.INST_COMBINE_PASS
  meta.AGGRESSIVE_DEAD_CODE_ELIMINATION_PASS
  meta.TRIGGER_DEDUPE_PASS
}

// Normal synth pipeline down to memory mapping, then lift for simulation.
FUNCTION_DEF %memoryTestSynthRoundTrip:func, :block {
  CALL %memoryTestSynth
  CALL %memoryTestLift
}

TEST_SCRIPT :string("test-memory-different-port-widths"), :block {
  PARSE_VERILOG_PASS map("code":[{
    module Test#(parameter int DEPTH = 128, parameter int WIDTH = 2) (
      input logic clk,
      input logic[$clog2(DEPTH) + $clog2(WIDTH) - 1:0] IN_waddr,
      input logic[0:0] IN_wdata,
      input logic[0:0] IN_wmask,

      input logic[$clog2(DEPTH) - 1:0] IN_raddr,
      output logic[1:0] OUT_rdata
    );

    union packed {
      logic[DEPTH-1:0][WIDTH-1:0] mem;
      logic[(DEPTH*WIDTH)-1:0] flat;
    } u;

    always_ff@(posedge clk)
      if (IN_wmask[0])
        u.flat[IN_waddr] <= IN_wdata;

    always_comb
      OUT_rdata = u.mem[IN_raddr];

    endmodule
  }])

  CALL %memoryTestSynth
  meta.ASSERT_EXISTS_PASS map("regex": "STDCELL_INSTANCE.+%FakeMem_3r1w_1x16.+#4'd0, #4'd0", "num": "16")
  CALL %memoryTestLift

  meta.RANDOM_EQUIVALENCE_CHECK_PASS map("cycles": "10000", "clockMode": "CLOCK")
}

TEST_SCRIPT :string("test-memory-basic"), :block {
  PARSE_VERILOG_PASS map("code":[{
    module Test#(parameter int DEPTH = 32, parameter int WIDTH = 32) (
      input logic clk,
      input logic[$clog2(DEPTH) - 1:0] IN_waddr,
      input logic[WIDTH-1:0] IN_wdata,
      input logic[0:0] IN_wmask,

      input logic[$clog2(DEPTH) - 1:0] IN_raddr,
      output logic[WIDTH-1:0] OUT_rdata
    );

    logic[WIDTH-1:0] mem[DEPTH-1:0];

    always_ff@(posedge clk)
      if (IN_wmask[0])
        mem[IN_waddr] <= IN_wdata;

    always_comb
      OUT_rdata = mem[IN_raddr];

    endmodule
  }])
  CALL %memoryTestSynth
  meta.ASSERT_EXISTS_PASS map("regex": "STDCELL_INSTANCE.+%FakeRAM_288", "num": "4")
  CALL %memoryTestLift
  meta.RANDOM_EQUIVALENCE_CHECK_PASS map("cycles": "10000", "clockMode": "CLOCK")
}

TEST_SCRIPT :string("test-ff-clken"), :block {
  PARSE_VERILOG_PASS map("code":[{
    module Test#(parameter int WIDTH = 32) (
      input logic clk,
      input logic en,

      input logic[WIDTH-1:0] d,
      output logic[WIDTH-1:0] q
    );

    always_ff@(posedge clk)
      if (en) q <= d;

    endmodule
  }])
  CALL %memoryTestSynth
  meta.ASSERT_EXISTS_PASS map("regex":
    "STDCELL_INSTANCE %[_a-zA-Z0-9]+:wire\(1\), %sky130_fd_sc_hd__edfxtp_1",
    "num": "32")
  CALL %memoryTestLift
  meta.RANDOM_EQUIVALENCE_CHECK_PASS map("cycles": "10000", "clockMode": "CLOCK")
}

TEST_SCRIPT :string("test-ff-srst-clken"), :block {
  PARSE_VERILOG_PASS map("code":[{
    module Test#(parameter int WIDTH = 32) (
      input logic clk,
      input logic rst,
      input logic en,

      input logic[WIDTH-1:0] d,
      output logic[WIDTH-1:0] q
    );

    always_ff@(posedge clk) begin
      if (rst)
        q <= '0;
      else if (en)
        q <= d;
    end

    endmodule
  }])
  CALL %memoryTestSynth
  meta.ASSERT_EXISTS_PASS map("regex":
    "STDCELL_INSTANCE %[_a-zA-Z0-9]+:wire\(1\), %sky130_fd_sc_hd__edfxtp_1",
    "num": "32")
  CALL %memoryTestLift
  meta.RANDOM_EQUIVALENCE_CHECK_PASS map("cycles": "10000", "clockMode": "CLOCK")
}

TEST_SCRIPT :string("test-ff-arst-clken"), :block {
  PARSE_VERILOG_PASS map("code":[{
    module Test#(parameter int WIDTH = 32) (
      input logic clk,
      input logic rst,
      input logic en,

      input logic[WIDTH-1:0] d,
      output logic[WIDTH-1:0] q
    );

    always_ff@(posedge clk or posedge rst) begin
      if (rst)
        q <= '0;
      else if (en)
        q <= d;
    end

    endmodule
  }])
  CALL %memoryTestSynth
  meta.ASSERT_EXISTS_PASS map("regex":
    "STDCELL_INSTANCE %[_a-zA-Z0-9]+:wire\(1\), %sky130_fd_sc_hd__dfrtp_1",
    "num": "32")
  CALL %memoryTestLift
  // run as comb to cover async rst
  meta.RANDOM_EQUIVALENCE_CHECK_PASS map("cycles": "10000", "clockMode": "COMB")
}

TEST_SCRIPT :string("test-memory-basic-sync-read"), :block {
  PARSE_VERILOG_PASS map("code":[{
    module Test#(parameter int DEPTH = 32, parameter int WIDTH = 32) (
      input logic clk,
      input logic[$clog2(DEPTH) - 1:0] IN_waddr,
      input logic[WIDTH-1:0] IN_wdata,
      input logic[0:0] IN_wmask,

      input logic IN_re,
      input logic[$clog2(DEPTH) - 1:0] IN_raddr,
      output logic[WIDTH-1:0] OUT_rdata
    );

    logic[WIDTH-1:0] mem[DEPTH-1:0];

    always_ff@(posedge clk)
      if (IN_wmask[0])
        mem[IN_waddr] <= IN_wdata;

    always_ff@(posedge clk)
      if (IN_re)
        OUT_rdata <= mem[IN_raddr];

    endmodule
  }])
  CALL %memoryTestSynth
