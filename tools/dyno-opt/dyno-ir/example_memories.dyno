STDCELL_DEF :module("FakeRAM_288"), :block {
  INPUT_REGISTER_DEF %clk:register(1)
  INPUT_REGISTER_DEF %IN_waddr:register(4)
  INPUT_REGISTER_DEF %IN_wdata:register(18)
  INPUT_REGISTER_DEF %IN_wmask:register(2)
  INPUT_REGISTER_DEF %IN_wen:register(1)
  INPUT_REGISTER_DEF %IN_raddr:register(4)
  OUTPUT_REGISTER_DEF %OUT_rdata:register(18)
  REGISTER_DEF %r11:register(288)
  TRIGGER_DEF %0:trigger(pos), %clk
  COMB_PROCESS_DEF :process, :block {
    LOAD %w34:wire(4), %IN_raddr
    ZEXT %w17:wire(32), %w34
    GEP %1:ptr, #32'd0, %w17, #32'd18, #32'd16
    MEM_LOAD %w31:wire(18), :mem_port(0), %r11, %1
    LOAD %w33:wire(4), %IN_waddr
    ZEXT %w14:wire(32), %w33
    LOAD %w28:wire(1), %IN_wen
    LOAD %w22:wire(18), %IN_wdata
    LOAD %w11:wire(2), %IN_wmask
    TRUNC %w5:wire(1), %w11
    AND %w18:wire(1), %w5, %w28
    TRUNC %w32:wire(9), %w22
    GEP %2:ptr, #32'd0, %w14, #32'd18, #32'd16
    MEM_STORE :mem_port(1), %w32, %r11, %w18, %2, %0
    SPLICE %w4:wire(1), %w11, #32'd1
    AND %w1:wire(1), %w4, %w28
    SPLICE %w19:wire(9), %w22, #32'd9
    GEP %3:ptr, #32'd9, %w14, #32'd18, #32'd16
    MEM_STORE :mem_port(1), %w19, %r11, %w1, %3, %0
    STORE %w31, %OUT_rdata
  }
}

STDCELL_DEF %FakeMem_3r1w_1x16:module("FakeMem_3r1w_1x16"), %0:block {
  INPUT_REGISTER_DEF %clk:register(1)
  INPUT_REGISTER_DEF %IN_waddr:register(4)
  INPUT_REGISTER_DEF %IN_wdata:register(1)
  INPUT_REGISTER_DEF %IN_wmask:register(1)
  INPUT_REGISTER_DEF %IN_raddr:register(4)
  OUTPUT_REGISTER_DEF %OUT_rdata:register(1)
  INPUT_REGISTER_DEF %IN_raddr2:register(4)
  OUTPUT_REGISTER_DEF %OUT_rdata2:register(1)
  INPUT_REGISTER_DEF %IN_raddr3:register(4)
  OUTPUT_REGISTER_DEF %OUT_rdata3:register(1)
  REGISTER_DEF %r11:register(16)
  TRIGGER_DEF %1:trigger(pos), %clk
  COMB_PROCESS_DEF %2:process, %3:block {
    LOAD %w20:wire(4), %IN_raddr
    ZEXT %w12:wire(32), %w20
    GEP %4:ptr, #32'd0, %w12, #32'd1, #32'd16
    MEM_LOAD %w21:wire(1), %5:mem_port(0), %r11, %4
    LOAD %w19:wire(4), %IN_raddr2
    ZEXT %w5:wire(32), %w19
    GEP %6:ptr, #32'd0, %w5, #32'd1, #32'd16
    MEM_LOAD %w2:wire(1), %7:mem_port(0), %r11, %6
    LOAD %w18:wire(4), %IN_raddr3
    ZEXT %w8:wire(32), %w18
    GEP %8:ptr, #32'd0, %w8, #32'd1, #32'd16
    MEM_LOAD %w22:wire(1), %9:mem_port(0), %r11, %8
    LOAD %w16:wire(1), %IN_wmask
    LOAD %w3:wire(4), %IN_waddr
    ZEXT %w13:wire(32), %w3
    LOAD %w0:wire(1), %IN_wdata
    GEP %10:ptr, #32'd0, %w13, #32'd1, #32'd16
    MEM_STORE %11:mem_port(1), %w0, %r11, %w16, %10, %1
    STORE %w21, %OUT_rdata
    STORE %w2, %OUT_rdata2
    STORE %w22, %OUT_rdata3
  }
}


