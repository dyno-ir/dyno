
PARSE_VERILOG_PASS map("code":[{
  module FakeRAM#(parameter int DEPTH = 16, parameter int WIDTH = 18) (
    input logic clk,
    input logic[$clog2(DEPTH) - 1:0] IN_waddr,
    input logic[WIDTH-1:0] IN_wdata,
    input logic IN_wmask0,
    input logic IN_wmask1,

    input logic[$clog2(DEPTH) - 1:0] IN_raddr,
    output logic[WIDTH-1:0] OUT_rdata
  );

  wire[WIDTH/9-1:0] IN_wmask = {IN_wmask1, IN_wmask0};

  logic[WIDTH-1:0] mem[DEPTH-1:0];

  always_ff@(posedge clk)
    for (int i = 0; i < WIDTH/9; i++)
      if (IN_wmask[i])
        mem[IN_waddr][i*9+:9] <= IN_wdata[i*9+:9];

  always_comb
    OUT_rdata = mem[IN_raddr];
  // always_ff@(posedge clk)
  //   OUT_rdata <= mem[IN_raddr];

  endmodule
}])

CALL symbol("flow_earlyCanonFlow")
CALL symbol("flow_synthCanonicalize")
CALL symbol("flow_synthEarlyOpt")
CALL symbol("flow_synthLowerControlFlow")
CALL symbol("flow_synthMemoryFFMuxHandling")

meta.DUMP_PASS map("path": "memory.dyno")
